<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.woi.healthcheck</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>cd /Users/Santiago/Desktop/Ai/Ninja_SAC/WOI/woi-listener &amp;&amp; node src/scripts/healthcheck.js || curl -X POST -H 'Content-Type: application/json' -d '{"text":":rotating_light: WOI healthcheck externo FAIL"}' "$SLACK_HEALTHCHECK_WEBHOOK"</string>
