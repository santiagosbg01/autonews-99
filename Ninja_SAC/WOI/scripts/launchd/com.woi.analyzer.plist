<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.woi.analyzer</string>

  <key>ProgramArguments</key>
  <array>
    <!-- Ajustar paths absolutos según la instalación real en el Mac Mini -->
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>cd /Users/Santiago/Desktop/Ai/Ninja_SAC/WOI/woi-analyzer &amp;&amp; .venv/bin/woi-analyze daily &gt;&gt; /Users/Santiago/Desktop/Ai/Ninja_SAC/WOI/logs/analyzer.log 2&gt;&amp;1</string>
  </array>

  <!-- 8:00 PM CDMX diario. launchd usa TZ del sistema (asumimos Mac Mini en CDMX). -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>20</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/Santiago/Desktop/Ai/Ninja_SAC/WOI/logs/analyzer.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/Santiago/Desktop/Ai/Ninja_SAC/WOI/logs/analyzer.stderr.log</string>
</dict>
</plist>
