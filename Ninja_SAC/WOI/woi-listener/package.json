{
  "name": "woi-listener",
  "version": "1.0.0",
  "description": "WOI — WhatsApp listener (Baileys) que ingesta mensajes de grupos operativos a Supabase",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "qr": "node src/index.js",
    "dev": "node --watch src/index.js",
    "restore-auth": "node src/scripts/restore-auth.js",
    "healthcheck": "node src/scripts/healthcheck.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart woi-listener",
    "pm2:logs": "pm2 logs woi-listener",
    "pm2:stop": "pm2 stop woi-listener"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@whiskeysockets/baileys": "^6.7.10",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "pm2": "^5.4.0"
  }
}
