# ============================================================
# WOI — Environment Variables Template
# Copiar a .env y llenar con valores reales. NO commitear .env.
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...                    # Solo para read-only desde UI
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # Para writes desde listener/analyzer
SUPABASE_DB_URL=postgresql://postgres.xxx:PASSWORD@aws-x-region.pooler.supabase.com:6543/postgres
SUPABASE_STORAGE_BUCKET=woi-auth-backup            # Bucket para backup de auth_state de Baileys

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_HAIKU_MODEL=claude-haiku-4-5                # Clasificación masiva
CLAUDE_SONNET_MODEL=claude-sonnet-4-5              # Ground-truth + resumen (env var para poder actualizar sin tocar código)
CLAUDE_MAX_TOKENS_CLASSIFY=400                     # Respuesta de clasificación es JSON corto
CLAUDE_MAX_TOKENS_SUMMARY=2000                     # Resumen ejecutivo
CLAUDE_CACHE_TTL=5m                                # Prompt caching

# ---- Slack ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
SLACK_CHANNEL_DM_SANTI=@santiago                   # DM de Santi o canal privado
SLACK_HEALTHCHECK_WEBHOOK=https://hooks.slack.com/services/...  # Opcional: canal separado para alertas de infra

# ---- Google Sheets ----
GOOGLE_SHEETS_CREDENTIALS_PATH=./google-credentials.json  # Service account JSON
GOOGLE_SHEETS_REPORT_ID=1xxxx_ID_del_sheet_del_reporte
GOOGLE_SHEETS_FEEDBACK_ID=1xxxx_ID_del_sheet_de_feedback_loop

# ---- Listener config ----
LISTENER_SIM_PHONE=521XXXXXXXXXX                   # Número del SIM primario (solo informativo)
LISTENER_SIM_STANDBY_PHONE=521YYYYYYYYYY           # Número standby
LISTENER_DISPLAY_NAME=99min Ops Monitor
LISTENER_AUTH_BACKUP_INTERVAL_MIN=60               # Sube auth_state a Supabase Storage cada N min
LISTENER_HEALTHCHECK_INTERVAL_SEC=300              # 5 min

# ---- Analyzer config ----
ANALYZER_BATCH_SIZE=50                             # Msgs por call a Haiku
ANALYZER_GROUND_TRUTH_DAILY_SAMPLE=100             # Msgs aleatorios/día para Sonnet ground-truth
ANALYZER_RUN_HOUR_CDMX=20                          # 8pm CDMX = job de análisis
ANALYZER_CONTEXT_MESSAGES=3                        # Mensajes previos como contexto para clasificación

# ---- Reporter config ----
REPORTER_RUN_HOUR_CDMX=21                          # 9pm CDMX = reporte
REPORTER_TIMEZONE=America/Mexico_City
REPORTER_TOP_INCIDENTS=10

# ---- Onboarding UI ----
STREAMLIT_PASSWORD=cambiar-esto-por-uno-fuerte     # Auth simple para la UI

# ---- Observabilidad ----
LOG_LEVEL=info                                     # debug | info | warn | error
LOG_DIR=./logs
NODE_ENV=production

# ---- Feature flags ----
FEATURE_INCIDENT_RECONSTRUCTION=true               # Se prende tras T0 spike
FEATURE_GROUND_TRUTH_SAMPLING=true
FEATURE_HUBSPOT_SYNC=false                         # V2
FEATURE_REALTIME_ALERTS=false                      # V2
